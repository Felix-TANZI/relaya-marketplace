# BelivaY — .gitignore

#  Variables d'environnement (CRITIQUE) 
# .env contient : clé secrète Django, password BDD, clé SMTP, API keys
.env
.env.*
.env.prod
frontend/.env
frontend/.env.*


#  Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/


#  Django
# Fichiers générés ou contenant des données utilisateur
*.sqlite3
db.sqlite3
media/          # photos avatars, produits, bannières, documents vendeur
mediafiles/     # alias utilisé en prod
staticfiles/    # fichiers static collectés par collectstatic


#  Environnements virtuels Python
.venv/
venv/
env/
ENV/


#  Node.js / Frontend
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
dist/
dist-ssr/
*.local


#  Logs──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


#  SSL / Certificats Let's Encrypt ──
# Générés par certbot — JAMAIS commités
certbot/
*.pem
*.key
*.crt
*.csr


#  Docker
# Overrides locaux non partagés
docker-compose.override.yml


#  Sauvegardes base de données
*.sql
*.dump
*.bak


#  Fichiers temporaires──
*.tmp
*.temp
*~


#  Tests & Coverage Python─
.coverage
htmlcov/
.pytest_cache/


#  OS─
.DS_Store
Thumbs.db


#  Éditeurs ─
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?